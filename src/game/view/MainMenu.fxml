      <ImageView fitHeight="1000.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="true" StackPane.alignment="BOTTOM_LEFT">
         <image>
            <Image url="@../resources/images/LaughersClosedDoor.png" />
         </image>
         <StackPane.margin>
            <Insets bottom="100.0" left="100.0" />
         </StackPane.margin>
      </ImageView>
      <ImageView fitHeight="1000.0" fitWidth="500.0" pickOnBounds="true" preserveRatio="true" StackPane.alignment="BOTTOM_RIGHT">
         <StackPane.margin>
            <Insets bottom="100.0" right="100.0" />
         </StackPane.margin>
         <image>
            <Image url="@../resources/images/ScarersClosedDoor.png" />
         </image>
      </ImageView>
   </children>
</StackPane>
