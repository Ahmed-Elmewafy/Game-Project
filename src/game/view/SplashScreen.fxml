<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>

<StackPane minHeight="720.0" minWidth="1280.0" styleClass="background" stylesheets="@SplashScreenStyle.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.engine.controller.SplashScreenController">
   <children>
      <ProgressBar fx:id="SplashScreenLoadingBar" prefWidth="200.0" progress="0.0" scaleX="1.5" scaleY="1.5" StackPane.alignment="BOTTOM_CENTER">
         <StackPane.margin>
            <Insets bottom="20.0" />
         </StackPane.margin>
      </ProgressBar>
   </children>
   <cursor>
      <Cursor fx:constant="NONE" />
   </cursor>
</StackPane>
