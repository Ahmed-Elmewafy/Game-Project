<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" minWidth="1280.0" minHeight="720.0"
           maxWidth="1280.0" maxHeight="720.0"
           styleClass="board-root"
           stylesheets="@Board.css"
           xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.controller.BoardController">

    <!-- Main layout HBox -->
    <HBox alignment="CENTER" spacing="0">

        <!-- ══ LEFT — PLAYER UI (290px) ════════════════════════════ -->
        <VBox fx:id="playerPanel"
              minWidth="290.0" maxWidth="290.0" minHeight="720.0"
              alignment="TOP_CENTER" spacing="0"
              styleClass="panel-strip">
            <padding><Insets top="6" bottom="6" left="8" right="8"/></padding>

            <VBox styleClass="side-panel" alignment="TOP_CENTER" spacing="3.0"
                  minWidth="272.0" minHeight="708.0" maxHeight="708.0">
                <padding><Insets top="6" bottom="6" left="8" right="8"/></padding>

                <!-- Monster image -->
                <StackPane styleClass="monster-img-frame"
                           minWidth="240.0" minHeight="120.0"
                           maxWidth="240.0" maxHeight="120.0">
                    <ImageView fx:id="playerImage"
                               fitWidth="240.0" fitHeight="120.0"
                               preserveRatio="true" smooth="true"
                               pickOnBounds="false"
                               StackPane.alignment="CENTER"/>
                </StackPane>

                <!-- Name -->
                <Label fx:id="playerName" styleClass="monster-name"
                       text="—" wrapText="true"
                       maxWidth="200.0" alignment="CENTER"/>

                <!-- Type + Role -->
                <HBox alignment="CENTER" spacing="6.0">
                    <Label fx:id="playerType" styleClass="monster-type" text="—"/>
                    <Label text="·" style="-fx-text-fill:#4a5a7a;-fx-font-family:Futura;"/>
                    <Label fx:id="playerRole" text="—"/>
                </HBox>

                <!-- Status Badges -->
                <HBox fx:id="playerStatusBox" alignment="CENTER" spacing="4.0" 
                      minHeight="22.0" maxHeight="22.0"/>

                <Pane minHeight="1.0"/>

                <!-- CANISTER -->
                <StackPane minWidth="80.0" maxWidth="80.0"
                           minHeight="105.0" maxHeight="105.0">
                    <AnchorPane minWidth="80.0" minHeight="105.0">
                        <Pane styleClass="energy-bar-track"
                              AnchorPane.leftAnchor="28.0" AnchorPane.rightAnchor="28.0"
                              AnchorPane.bottomAnchor="37.0" AnchorPane.topAnchor="39.0"/>
                        <Pane fx:id="playerEnergyFill"
                              styleClass="energy-bar-fill"
                              AnchorPane.leftAnchor="28.0" AnchorPane.rightAnchor="28.0"
                              AnchorPane.bottomAnchor="37.0"
                              prefHeight="0.0"/>
                    </AnchorPane>
                    <ImageView fx:id="playerCanisterImage"
                               fitWidth="80.0" fitHeight="80.0"
                               preserveRatio="true" smooth="true" mouseTransparent="true"
                               StackPane.alignment="CENTER">
                        <image><Image url="@../resources/images/Board/UI/Cannister.png"/></image>
                    </ImageView>
                </StackPane>

                <!-- Energy -->
                <Label styleClass="micro-header" text="ENERGY"/>
                <Label fx:id="playerEnergy" styleClass="energy-value" text="0"/>

                <!-- Position -->
                <Label styleClass="micro-header" text="POSITION"/>
                <Label fx:id="playerPosition" styleClass="position-value" text="Cell 0"/>

                <Pane minHeight="3.0"/>

                <!-- Buttons -->
                <Button fx:id="playerPlayTurnBtn" styleClass="btn-play-turn"
                        text="Play Turn [Space]" onAction="#onPlayerPlayTurn"/>
                <Button fx:id="playerPowerupBtn" styleClass="btn-powerup"
                        text="Use Powerup [S]" onAction="#onPlayerUsePowerup"/>

                <Pane minHeight="3.0"/>

                <!-- Player Log -->
                <Label styleClass="micro-header" text="BATTLE LOG"/>
                <ImageView fx:id="playerDiceImage"
                           fitWidth="52.0" fitHeight="52.0"
                           preserveRatio="true" smooth="true"
                           visible="false"/>
                <ScrollPane fx:id="playerLogScroll" styleClass="log-scroll"
                            fitToWidth="true" hbarPolicy="NEVER"
                            minHeight="160.0" maxHeight="220.0"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="playerLogBox" styleClass="log-box" spacing="2.0">
                        <padding><Insets top="4" bottom="4" left="6" right="6"/></padding>
                    </VBox>
                </ScrollPane>

            </VBox>
        </VBox>

        <!-- ══ CENTRE — 10×10 GRID (700px) ═════════════════════════ -->
        <VBox alignment="CENTER" spacing="0"
              minWidth="700.0" maxWidth="700.0"
              style="-fx-background-color: #c8b88a;">
            <StackPane styleClass="board-grid-container"
                       minWidth="700.0" maxWidth="700.0"
                       minHeight="720.0" maxHeight="720.0">
                  <GridPane fx:id="boardGrid"
                            minWidth="700.0" maxWidth="700.0"
                            minHeight="720.0" maxHeight="720.0"
                            hgap="0" vgap="0"
                            StackPane.alignment="CENTER">
                      <columnConstraints>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                          <ColumnConstraints minWidth="70.0" maxWidth="70.0" prefWidth="70.0"/>
                      </columnConstraints>
                      <rowConstraints>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                          <RowConstraints minHeight="72.0" maxHeight="72.0" prefHeight="72.0"/>
                      </rowConstraints>
                  </GridPane>

              </StackPane>
        </VBox>

        <!-- ══ RIGHT — OPPONENT UI (290px) ═════════════════════════ -->
        <VBox fx:id="opponentPanel"
              minWidth="290.0" maxWidth="290.0" minHeight="720.0"
              alignment="TOP_CENTER" spacing="0"
              styleClass="panel-strip">
            <padding><Insets top="6" bottom="6" left="8" right="8"/></padding>

            <VBox styleClass="side-panel" alignment="TOP_CENTER" spacing="3.0"
                  minWidth="272.0" minHeight="708.0" maxHeight="708.0">
                <padding><Insets top="6" bottom="6" left="8" right="8"/></padding>

                <StackPane styleClass="monster-img-frame"
                           minWidth="240.0" minHeight="120.0"
                           maxWidth="240.0" maxHeight="120.0">
                    <ImageView fx:id="opponentImage"
                               fitWidth="240.0" fitHeight="120.0"
                               preserveRatio="true" smooth="true"
                               pickOnBounds="false"
                               StackPane.alignment="CENTER"/>
                </StackPane>

                <Label fx:id="opponentName" styleClass="monster-name"
                       text="—" wrapText="true"
                       maxWidth="200.0" alignment="CENTER"/>

                <HBox alignment="CENTER" spacing="6.0">
                    <Label fx:id="opponentType" styleClass="monster-type" text="—"/>
                    <Label text="·" style="-fx-text-fill:#4a5a7a;-fx-font-family:Futura;"/>
                    <Label fx:id="opponentRole" text="—"/>
                </HBox>

                <!-- Status Badges -->
                <HBox fx:id="opponentStatusBox" alignment="CENTER" spacing="4.0" 
                      minHeight="22.0" maxHeight="22.0"/>

                <Pane minHeight="1.0"/>

                <StackPane minWidth="80.0" maxWidth="80.0"
                           minHeight="105.0" maxHeight="105.0">
                    <AnchorPane minWidth="80.0" minHeight="105.0">
                        <Pane styleClass="energy-bar-track"
                              AnchorPane.leftAnchor="28.0" AnchorPane.rightAnchor="28.0"
                              AnchorPane.bottomAnchor="37.0" AnchorPane.topAnchor="39.0"/>
                        <Pane fx:id="opponentEnergyFill"
                              styleClass="energy-bar-fill"
                              AnchorPane.leftAnchor="28.0" AnchorPane.rightAnchor="28.0"
                              AnchorPane.bottomAnchor="37.0"
                              prefHeight="0.0"/>
                    </AnchorPane>
                    <ImageView fx:id="opponentCanisterImage"
                               fitWidth="80.0" fitHeight="80.0"
                               preserveRatio="true" smooth="true" mouseTransparent="true"
                               StackPane.alignment="CENTER">
                        <image><Image url="@../resources/images/Board/UI/Cannister.png"/></image>
                    </ImageView>
                </StackPane>

                <Label styleClass="micro-header" text="ENERGY"/>
                <Label fx:id="opponentEnergy" styleClass="energy-value" text="0"/>

                <Label styleClass="micro-header" text="POSITION"/>
                <Label fx:id="opponentPosition" styleClass="position-value" text="Cell 0"/>

                <Pane minHeight="3.0"/>

                <Button fx:id="opponentPlayTurnBtn" styleClass="btn-play-turn"
                        text="Play Turn [Enter]" onAction="#onOpponentPlayTurn" disable="true"/>
                <Button fx:id="opponentPowerupBtn" styleClass="btn-powerup"
                        text="Use Powerup [L]" onAction="#onOpponentUsePowerup" disable="true"/>

                <Pane minHeight="3.0"/>

                <!-- Opponent Log -->
                <Label styleClass="micro-header" text="BATTLE LOG"/>
                <ImageView fx:id="opponentDiceImage"
                           fitWidth="52.0" fitHeight="52.0"
                           preserveRatio="true" smooth="true"
                           visible="false"/>
                <ScrollPane fx:id="opponentLogScroll" styleClass="log-scroll"
                            fitToWidth="true" hbarPolicy="NEVER"
                            minHeight="160.0" maxHeight="220.0"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="opponentLogBox" styleClass="log-box" spacing="2.0">
                        <padding><Insets top="4" bottom="4" left="6" right="6"/></padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </VBox>

    </HBox>




    <!-- ══ POPUP OVERLAY LAYER — for cards, monster encounters, exceptions ══ -->
    <StackPane fx:id="popupOverlay" visible="false"
               style="-fx-background-color: rgba(0,0,0,0.7);"
               minWidth="1280.0" minHeight="720.0">
        <VBox fx:id="popupContent" alignment="CENTER" spacing="14.0"
              style="-fx-background-color: rgba(15,20,40,0.95);
                     -fx-background-radius: 16; -fx-border-color: #c8a84b;
                     -fx-border-width: 2; -fx-border-radius: 16;">
            <padding><Insets top="20" bottom="20" left="28" right="28"/></padding>
        </VBox>
    </StackPane>

</StackPane>
